<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Totoro.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Totoro.Maui"
    xmlns:views="clr-namespace:Totoro.Maui.Views"
    Loaded="Shell_Loaded"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab>
            <ShellContent Title="Watching" ContentTemplate="{DataTemplate views:UserListPage}" />
            <ShellContent Title="Plan To Watch" ContentTemplate="{DataTemplate views:UserListPage}" />
            <ShellContent Title="On Hold" ContentTemplate="{DataTemplate views:UserListPage}" />
            <ShellContent Title="Completed" ContentTemplate="{DataTemplate views:UserListPage}" />
            <ShellContent Title="Dropped" ContentTemplate="{DataTemplate views:UserListPage}" />
        </Tab>
        <Tab Title="Discover">
            <ShellContent
                Title="Home"
                ContentTemplate="{DataTemplate views:DiscoverPage}"
                Route="DiscoverViewModel" />
        </Tab>
    </TabBar>

</Shell>
