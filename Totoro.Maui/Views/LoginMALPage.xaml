<?xml version="1.0" encoding="utf-8" ?>
<rx:ReactiveContentPage
    x:Class="Totoro.Maui.Views.LoginMALPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:rx="clr-namespace:ReactiveUI.Maui;assembly=ReactiveUI.Maui"
    xmlns:vm="clr-namespace:Totoro.Maui.ViewModels"
    Title="Login"
    x:DataType="vm:LoginMALViewModel"
    x:TypeArguments="vm:LoginMALViewModel">
    <WebView Navigated="WebView_Navigated" Source="{Binding AuthUrl, Mode=TwoWay}" />
</rx:ReactiveContentPage>